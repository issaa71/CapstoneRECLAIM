  <!-- ══════════════════════════════════════════════════ -->
  <!-- Gripper: child of tool0, OUTSIDE MoveIt2 chain   -->
  <!-- 0 rad = fully open (1400µs)                      -->
  <!-- 0.836 rad = fully closed (1755µs)                -->
  <!-- ══════════════════════════════════════════════════ -->
  <link name="gripper_link">
    <inertial>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <mass value="0.142"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
  </link>
  <joint name="gripper_joint" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="tool0"/>
    <child link="gripper_link"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.0" upper="0.836" effort="5" velocity="2"/>
  </joint>

  <!-- ══════════════════════════════════════════════════ -->
  <!-- Camera: OAK-D Lite mounted on wrist_pitch_link   -->
  <!-- Offset measured from CAD: (-55mm, -12mm, +64mm)  -->
  <!-- Camera looks along wrist_pitch_link Z axis       -->
  <!-- ══════════════════════════════════════════════════ -->
  <link name="camera_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.061"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
  </link>
  <joint name="wrist_to_camera" type="fixed">
    <origin xyz="-0.068 -0.012 0.064" rpy="0 0 0"/>
    <parent link="wrist_pitch_link"/>
    <child link="camera_link"/>
  </joint>

  <!-- Optical frame: camera_link has Z=forward (along arm) -->
  <!--   camera_optical_frame: X right, Y down, Z forward  -->
  <!--   Rotation maps: Z_cam→Z_opt, -Y_cam→X_opt, -X_cam→Y_opt -->
  <!--   This may need tuning if image appears flipped      -->
  <link name="camera_optical_frame"/>
  <joint name="camera_to_optical" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 -1.5708"/>
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
  </joint>

  <!-- ══════════════════════════════════════════════════ -->
  <!-- ros2_control: Servo Hardware Interface            -->
  <!-- Calibration from March 19, 2026                   -->
  <!-- ══════════════════════════════════════════════════ -->
  <ros2_control name="servo_hardware" type="system">
    <hardware>
      <plugin>reclaim_servo_hardware/ServoHardwareInterface</plugin>
      <param name="serial_port">/tmp/teensy_arm</param>
      <param name="baud_rate">115200</param>
    </hardware>

    <!-- J1 Base — DS3218 270° — not inverted -->
    <joint name="base_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <param name="zero_us">1229</param>
      <param name="scale">0.002356</param>
      <param name="inverted">false</param>
      <param name="min_us">400</param>
      <param name="max_us">2600</param>
    </joint>

    <!-- J2 Shoulder — DS3240 270° — not inverted (axis 0 -1 0) -->
    <joint name="shoulder_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <param name="zero_us">1673</param>
      <param name="scale">0.002356</param>
      <param name="inverted">false</param>
      <param name="min_us">995</param>
      <param name="max_us">2553</param>
    </joint>

    <!-- J3 Elbow — DS3218 270° — not inverted -->
    <joint name="elbow_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <param name="zero_us">1320</param>
      <param name="scale">0.002356</param>
      <param name="inverted">false</param>
      <param name="min_us">680</param>
      <param name="max_us">2380</param>
    </joint>

    <!-- J4 Wrist Pitch — DS3218 270° — not inverted (axis 0 -1 0) -->
    <joint name="wrist_pitch_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <param name="zero_us">2230</param>
      <param name="scale">0.002356</param>
      <param name="inverted">false</param>
      <param name="min_us">1410</param>
      <param name="max_us">2600</param>
    </joint>

    <!-- J6 Gripper — DS3218 + LewanSoul claw -->
    <!-- 0 rad = fully open (1400µs), 0.836 rad = fully closed (1755µs) -->
    <joint name="gripper_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <param name="zero_us">1400</param>
      <param name="scale">0.002356</param>
      <param name="inverted">false</param>
      <param name="min_us">1400</param>
      <param name="max_us">1755</param>
    </joint>
  </ros2_control>

</robot>